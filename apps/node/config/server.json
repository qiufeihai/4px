{
  "listenHost": "0.0.0.0",
  "listenPort": 6666,
  "tls": {
    "keyFile": "/root/.acme.sh/zyko2.online_ecc/zyko2.online.key",
    "certFile": "/root/.acme.sh/zyko2.online_ecc/fullchain.cer"
  },
  "authTokens": [
    "change-me-strong-token"
  ],
  "authUsersFile": "server.users.json",
  "authUsersReloadIntervalMs": 5000,
  "userActivityUpdateIntervalMs": 60000,
  "defaultMaxDevices": 1,
  "deviceLeaseTtlMs": 90000,
  "deviceLimitPolicy": "reject",
  "admin": {
    "enabled": true,
    "listenHost": "0.0.0.0",
    "listenPort": 6688,
    "token": "change-me-admin-token"
  },
  "logLevel": "WARN",
  "maxBufferedBytes": 4194304,
  "metricsIntervalMs": 30000,
  "establishWarnThresholdMs": 1500,
  "listenBacklog": 4096,
  "h2HeaderTableSize": 4096,
  "h2InitialWindowSize": 1048576,
  "h2MaxConcurrentStreams": 1024,
  "h2MaxFrameSize": 65536,
  "h2MaxHeaderListSize": 65536,
  "h2EnableConnectProtocol": false,
  "remoteConnectTimeoutMs": 15000,
  "remoteIdleTimeoutMs": 300000,
  "remoteKeepAliveInitialDelayMs": 30000,
  "streamIdleTimeoutMs": 300000
}
