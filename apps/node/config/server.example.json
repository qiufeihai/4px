{
  "listenHost": "0.0.0.0",
  "listenPort": 6666,
  "tls": {
    "keyFile": "/root/.acme.sh/zyko2.online_ecc/zyko2.online.key",
    "certFile": "/root/.acme.sh/zyko2.online_ecc/fullchain.cer"
  },
  "authTokens": [
    "change-me-strong-token"
  ],
  "authUsersFile": "server.users.json",
  "authUsersReloadIntervalMs": 5000,
  "defaultMaxDevices": 1,
  "deviceLeaseTtlMs": 90000,
  "deviceLimitPolicy": "reject",
  "deviceTicket": {
    "enabled": true,
    "secret": "CHANGE_ME_DEVICE_TICKET_SECRET",
    "ttlMs": 3600000,
    "require": true
  },
  "deviceLeaseStore": {
    "mode": "redis",
    "bindPeerIp": true,
    "prefix": "4px:device_lease",
    "redis": {
      "enabled": false,
      "url": "redis://127.0.0.1:6379",
      "password": "CHANGE_ME_REDIS_PASSWORD",
      "database": 0,
      "connectTimeoutMs": 5000
    }
  },
  "admin": {
    "enabled": true,
    "listenHost": "0.0.0.0",
    "listenPort": 6688,
    "token": "change-me-admin-token",
    "serviceControl": {
      "enabled": false,
      "systemdService": "4px",
      "useSudo": true
    },
    "clientConfigExport": {
      "upstreamHost": "your-server-ip",
      "upstreamPort": 6666,
      "serverName": "your-server-domain",
      "rejectUnauthorized": true,
      "caFile": ""
    }
  },
  "logLevel": "WARN",
  "maxBufferedBytes": 4194304,
  "metricsIntervalMs": 120000,
  "slowEstablishEnabled": false,
  "establishWarnThresholdMs": 1500,
  "establishWarnMinIntervalMs": 5000,
  "listenBacklog": 4096,
  "h2HeaderTableSize": 4096,
  "h2InitialWindowSize": 1048576,
  "h2MaxConcurrentStreams": 1024,
  "h2MaxFrameSize": 65536,
  "h2MaxHeaderListSize": 65536,
  "remoteConnectTimeoutMs": 15000,
  "remoteConnectMaxInFlight": 4096,
  "remoteConnectMaxInFlightPerHost": 1024,
  "remoteConnectOverloadWaitMs": 20,
  "remoteConnectOverloadMaxWaiters": 1024,
  "remoteConnectOverloadLogMinIntervalMs": 3000,
  "remoteDnsCacheTtlMs": 60000,
  "remoteDnsNegativeCacheTtlMs": 5000,
  "remoteDnsCacheMaxEntries": 4096,
  "remoteCircuitFailureThreshold": 8,
  "remoteCircuitOpenMs": 15000,
  "remoteCircuitLogMinIntervalMs": 3000,
  "remoteCircuitMaxTargets": 4096,
  "remoteIdleTimeoutMs": 300000,
  "remoteKeepAliveInitialDelayMs": 30000,
  "streamIdleTimeoutMs": 300000,
  "remoteErrorLogMinIntervalMs": 3000,
  "slowEstablishSummaryIntervalMs": 300000,
  "metricsReporter": {
    "enabled": true
  },
  "deviceLeaseTouchMinIntervalMs": 5000,
  "camouflageRateLimit": {
    "windowMs": 10000,
    "maxRequests": 30
  }
}
