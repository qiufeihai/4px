{
  "socksListenHost": "127.0.0.1",
  "socksListenPort": 7777,
  "upstream": {
    "host": "your-server-ip",
    "port": 6666,
    "path": "/proxy",
    "serverName": "your-server-domain",
    "authToken": "change-me-strong-token",
    "deviceTicket": "",
    "rejectUnauthorized": true
  },
  "logLevel": "WARN",
  "h2SessionPoolSize": 1,
  "maxBufferedBytes": 4194304,
  "metricsIntervalMs": 30000,
  "sessionHeartbeatIntervalMs": 30000,
  "socksListenBacklog": 4096,
  "upstreamConnectTimeoutMs": 15000,
  "streamResponseTimeoutMs": 30000,
  "streamIdleTimeoutMs": 300000,
  "localSocketKeepAliveInitialDelayMs": 30000,
  "localSocketIdleTimeoutMs": 120000,
  "localAuth": {
    "enabled": false,
    "username": "local-user",
    "password": "local-pass"
  },
  "httpListen": "127.0.0.1:7788",
  "httpListenBacklog": 4096
}
